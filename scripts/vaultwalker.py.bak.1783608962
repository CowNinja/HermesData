def load_config() -> Dict:
    cfg = None
    if CONFIG_PATH_YAML.exists():
        try:
            import yaml
            with open(CONFIG_PATH_YAML, "r", encoding="utf-8") as f:
                cfg = yaml.safe_load(f)
            print("[CONFIG] Loaded data_silos.yaml v0.5 (full post encapsulation + v0.5 iterations)")
        except Exception as e:
            print(f"[CONFIG WARN] yaml: {e}")
    if cfg is None and CONFIG_PATH_JSON.exists():
        try:
            with open(CONFIG_PATH_JSON, "r", encoding="utf-8") as f:
                cfg = json.load(f)
        except Exception as e:
            print(f"[CONFIG ERR] {e}. Fallback.")
    if cfg is None:
        # Minimal fallback with v0.5 structure
        return {
            "version": "0.5",
            "global": {"iteration_policies": {"persistent_state": True, "staggered_cycles": True, "agent_diagnostics": True, "human_verification": True, "executable_templates": True, "trend_tracking": True, "local_models": True}},
            "silos": {name: {"path": str(p), "local_first": True, "update_per_folder_indexes": True, "non_ascii_code_clean": True if name != "K_PhronesisSovereign" else False, "md_review": name != "K_PhronesisSovereign", "vision_ref": r"D:\PhronesisVault\docs\agent-coordination\Grand-Vision-Master-Plan-Addendum-2026-06-26.md"} for name, p in {"HermesData": r"D:\HermesData", "PhronesisVault": r"D:\PhronesisVault", "K_PhronesisSovereign": r"K:\Phronesis-Sovereign", "RoleplaySandbox": r"D:\PhronesisVault\Roleplay-Sandbox"}.items()}
        }
    return cfg

CFG = load_config()
SILOS = {name: Path(s["path"]) for name, s in CFG.get("silos", {}).items()}
GLOBAL_POLICIES = CFG.get("global", {}).get("iteration_policies", {})
STALE_DAYS = CFG.get("global", {}).get("stale_days", 60)
DEFAULT_OLLAMA = CFG.get("global", {}).get("local_ollama_model", "phi3:mini")

def is_light_cycle() -> bool:
    """Staggered: even run = light (indexes + quick), odd = deep (full PKG/review/self-evo)."""
    if not GLOBAL_POLICIES.get("staggered_cycles", True):
        return False
    run_count = 0
    if TRENDS_FILE.exists():
        try:
            with open(TRENDS_FILE, "r") as f:
                trends = json.load(f)
                run_count = trends.get("total_runs", 0)
        except:
            pass
    return run_count % 2 == 0

def local_ollama_call(prompt: str, model: str = None) -> str:
    """Local-first semantic work. Falls back gracefully."""
    if not GLOBAL_POLICIES.get("local_models", True):
        return ""
    model = model or DEFAULT_OLLAMA
    try:
        result = subprocess.run(
            ["ollama", "run", model, prompt],
            capture_output=True, text=True, timeout=90
        )
        if result.returncode == 0:
            return result.stdout.strip()[:2500]
        return ""
    except Exception as e:
        return f"[OLLAMA_UNAVAILABLE: {str(e)[:80]}]"

def file_hash(path: Path) -> str:
    sha = hashlib.sha256()
    try:
        with open(path, "rb") as f:
            for chunk in iter(lambda: f.read(65536), b""):
                sha.update(chunk)
        return sha.hexdigest()[:16]
    except:
        return "ERROR"

def sanitize_non_ascii(text: str) -> str:
    normalized = unicodedata.normalize("NFKD", text)
    ascii_only = re.sub(r"[^\x00-\x7F]+", "", normalized)
    return re.sub(r"\s+", " ", ascii_only).strip() or "sanitized"

def load_vision_ref(path_str: str) -> str:
    try:
        p = Path(path_str)
        if p.exists():
            return p.read_text(encoding="utf-8", errors="ignore")[:6000]
    except:
        pass
    return "T0 silo population PRIMARY; Wisdom Keeper (Vault=how we work, K=what lived); T2 hygiene continuous; PKG entities/relations user-centric; separation scaffolding; self-evolving skills."

def load_persistent_state(silo_name: str) -> Dict[str, Any]:
    """v0.5 persistent cross-run state for incremental."""
    if not GLOBAL_POLICIES.get("persistent_state", True):
        return {}
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    state_file = STATE_DIR / f"{silo_name.lower()}_state.json"
    if state_file.exists():
        try:
            with open(state_file, "r", encoding="utf-8") as f:
                return json.load(f)
        except:
            return {}
    return {}

def save_persistent_state(silo_name: str, state: Dict[str, Any]) -> None:
    if not GLOBAL_POLICIES.get("persistent_state", True):
        return
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    state_file = STATE_DIR / f"{silo_name.lower()}_state.json"
    state["last_updated"] = datetime.now().isoformat()
    try:
        with open(state_file, "w", encoding="utf-8") as f:
            json.dump(state, f, indent=2)
    except Exception as e:
        print(f"[STATE WARN] {e}")

def should_process_deep(path: Path, state: Dict[str, Any]) -> bool:
    """Incremental: skip if mtime + hash unchanged since last deep run."""
    if not GLOBAL_POLICIES.get("persistent_state", True):
        return True
    key = str(path.relative_to(path.anchor)) if path.is_absolute() else str(path)
    last = state.get("folders", {}).get(key, {})
    try:
        mtime = path.stat().st_mtime
        h = file_hash(path) if path.is_file() else "dir"
        if last.get("mtime") == mtime and last.get("hash") == h:
            return False
        state.setdefault("folders", {})[key] = {"mtime": mtime, "hash": h}
        return True
    except:
        return True

def update_per_folder_indexes(root: Path, silo_name: str, state: Dict[str, Any], is_light: bool) -> int:
    """v0.5: Separation scaffolding + executable templates (sample agent prompts per post 5)."""
    updated = 0
    if not root.exists():
        return 0
    for dirpath in root.rglob("*"):
        if not dirpath.is_dir():
            continue
        if any(x in str(dirpath).lower() for x in ["node_modules", ".git", "__pycache__", "tmp"]):
            continue
        if not should_process_deep(dirpath, state):
            continue
        is_archive = "archive" in str(dirpath).lower()
        files = [f for f in dirpath.iterdir() if f.is_file()]
        if len(files) < 1:
            continue
        idx_file = dirpath / "00-INDEX.md" if not (dirpath / "INDEX.md").exists() else dirpath / "INDEX.md"
        content = f"# {dirpath.name} — INDEX Map (VaultWalker v0.5, {datetime.now().strftime('%Y-%m-%d')}) Silo: {silo_name}\n\n"
        content += "**Encapsulates post 2073071937979347129 + 2071860243911356416 (Separation of concerns):**\n"
        content += "One concern/project folder. Numbered where stable. Agent reads this INDEX FIRST. Do not wander.\n\n"
        content += f"**Where To Go (executable agent instructions):**\n"
        content += "- Start here. Follow canonicals and subfolders.\n"
        content += "- For resurfacing forgotten ideas (post 2074255821211312609): check mtime >60d and link back.\n"
        content += "- For PKG (post 2074069045561717168): identify entities/relations; add YAML if missing; link on entry.\n"
        content += "- For self-evolution (post 2072802530883752030): note patterns → propose skills.\n"
        content += "- Archive? Skip unless historical context requested.\n\n"
        if GLOBAL_POLICIES.get("executable_templates", True):
            content += "**Sample Agent Prompt (read this map then act):**\n"
            content += "``` \nRead this INDEX first. Use 'Where To Go'. Update PKG metadata. Resurface stale connections. Extract one reusable skill if pattern found. Link bidirectionally to masters.\n```\n\n"
        content += f"Files: {len(files)} | Archive: {is_archive}\n\n"
        content += "## Canonical / Current (MOC-style high-signal)\n"
        for f in sorted(files, key=lambda x: x.stat().st_mtime, reverse=True)[:12]:
            content += f"- [[{f.name}]] ({f.stat().st_size} bytes)\n"
        content += "\n**Post principles active**: PKG layers | Atomic | Link-on-entry | Resurface | Self-evolution | Separation scaffolding.\n"
        try:
            with open(idx_file, "w", encoding="utf-8") as fh:
                fh.write(content)
            updated += 1
        except:
            continue
    return updated

def clean_code_non_ascii(root: Path) -> int:
    cleaned = 0
    exts = {".py", ".sh", ".yaml", ".yml", ".js", ".ps1", ".bat", ".toml"}
    for p in root.rglob("*"):
        if p.is_file() and p.suffix.lower() in exts:
            try:
                txt = p.read_text(encoding="utf-8", errors="ignore")
                if any(ord(c) > 127 for c in txt):
                    san = sanitize_non_ascii(txt)
                    if san != txt:
                        # Always create timestamped backup for safety
                        ts = datetime.now().strftime("%Y%m%d-%H%M%S")
                        bak = p.with_name(p.name + f".{ts}.bak")
                        with open(bak, "w", encoding="utf-8") as bf:
                            bf.write(txt)
                        with open(p, "w", encoding="utf-8") as f:
                            f.write(san)
                        cleaned += 1
                        # Post-clean validation for Python to prevent breaking execution
                        if p.suffix.lower() == ".py":
                            try:
                                import py_compile
                                py_compile.compile(str(p), doraise=True)
                            except Exception as ve:
                                # Restore from the backup we just made
                                with open(bak, "r", encoding="utf-8") as bf:
                                    with open(p, "w", encoding="utf-8") as f:
                                        f.write(bf.read())
                                print(f"[NON-ASCII] Validation failed on {p} — restored from backup. Error: {ve}")
            except Exception as e:
                continue
    return cleaned

def review_and_modify_markdowns(root, vision_text, silo_name, state, is_light):
    """Review MDs: add PKG YAML frontmatter (bulletproof with triple quotes), add resurfacing/splitting notes.
    Uses triple-quoted strings for the YAML block to eliminate any possibility of unterminated string literal errors.
    Clean, readable, efficient.
    """
    stats = {"reviewed": 0, "pkg_entities": 0, "pkg_relations": 0, "resurfaced": 0, "alignment_score": 0.0, "proposals": 0, "notes": ""}
    if not root.exists() or is_light:
        return stats
    for p in root.rglob("*.md"):
        if not should_process_deep(p, state):
            continue
        try:
            text = p.read_text(encoding="utf-8", errors="ignore")
            stats["reviewed"] += 1
            orig = text
            changed = False
            if not text.startswith("---") and len(text) > 300:
                # Bulletproof: triple-quoted YAML frontmatter
                date_str = __import__("datetime").datetime.now().strftime("%Y-%m-%d")
                pkg = """---
type: note
status: active
entities: []
relations: []
review_date: {date}
topic: general
silo: {silo}
---

""".format(date=date_str, silo=silo_name)
                text = pkg + text
                stats["pkg_entities"] += 1
                changed = True
            if len(text) > 5000 and "## " not in text[800:]:
                text += "\n\n> Consider splitting into atomic notes for PKG and resurfacing."
                changed = True
            if "[[" not in text[:400] and len(text) > 250:
                text += "\n\n> Link on entry + resurface: Connect to MOC or entity."
                stats["resurfaced"] += 1
                changed = True
            if changed and text != orig:
                dry = getattr(__import__("sys").modules.get("__main__"), "args", type("a", (), {"dry_run": False})()).dry_run
                if not dry:
                    try:
                        p.write_text(text, encoding="utf-8")
                    except Exception:
                        pass
                stats["proposals"] += 1
        except Exception:
            continue
    return stats

def self_evolve_extract_skills(root: Path, silo_name: str, state: Dict[str, Any], is_light: bool) -> Dict:
    """Self-evolution + structured proposals + human verification (post 2072802530883752030)."""
    stats = {"skills": 0, "workflows": 0, "proposals_generated": 0, "examples": []}
    if not root.exists() or is_light:
        return stats
    patterns = [(r"(workflow|process|routine|automation|daily|12h)", "workflow"), (r"(skill|prompt|agent behavior|self)", "skill")]
    for p in root.rglob("*.md"):
        if not should_process_deep(p, state):
            continue
        try:
            txt = p.read_text(encoding="utf-8", errors="ignore").lower()
            for pat, cat in patterns:
                if re.search(pat, txt):
                    rel = str(p.relative_to(root))
                    ex = f"{cat} from {rel}"
                    if len(stats["examples"]) < 4:
                        stats["examples"].append(ex)
                    if cat == "workflow":
                        stats["workflows"] += 1
                    else:
                        stats["skills"] += 1
        except:
            continue
    if stats["skills"] + stats["workflows"] > 0 and GLOBAL_POLICIES.get("human_verification", True):
        SKILLS_DIR.mkdir(parents=True, exist_ok=True)
        PROPOSALS_DIR.mkdir(parents=True, exist_ok=True)
        prop_name = f"self-evolve-{silo_name}-{datetime.now().strftime('%Y%m%d-%H%M')}.md"
        prop_path = PROPOSALS_DIR / prop_name
        content = f"---\nname: {prop_name}\ncategory: self-evolution\nsilo: {silo_name}\ntimestamp: {datetime.now().isoformat()}\n---\n\n"
        content += f"## Self-Evolution Proposal (post 2072802530883752030)\n{stats}\n\nExamples:\n"
        for e in stats["examples"]:
            content += f"- {e}\n"
        content += "\n**Human verification required.** Diffs would be here in full run. Absorb via curator/skills tool if approved.\n"
        if not args.dry_run:
            with open(prop_path, "w", encoding="utf-8") as f:
                f.write(content)
        stats["proposals_generated"] = 1
    return stats


def resurface_forgotten_ideas(root: Path, silo_name: str, state: Dict[str, Any]) -> Dict:
    """Actively resurface forgotten ideas (post 2074255821211312609 + PKG resurface shift).
    Scans for stale/low-link content. Appends to Resurfaced-Ideas.md for easy access.
    Adds resurfacing notes to files. Proposes connections for intuitive navigation.
    """
    stats = {"stale_found": 0, "surfaced": 0, "resurfaced_ideas": 0, "examples": []}
    if not root.exists():
        return stats
    now = datetime.now()
    resurf_log = root / "Resurfaced-Ideas.md"
    entries = []
    for p in root.rglob("*.md"):
        if not should_process_deep(p, state): continue
        try:
            mtime = datetime.fromtimestamp(p.stat().st_mtime)
            days_old = (now - mtime).days
            text = p.read_text(encoding="utf-8", errors="ignore")
            links = text.count("[[")
            if days_old > STALE_DAYS or (links < 2 and len(text) > 250 and "archive" not in str(p).lower()):
                rel = str(p.relative_to(root))
                entry = f"- [[{rel}]] (~{days_old}d, {links} links) — resurfaced for connection"
                stats["stale_found"] += 1
                stats["surfaced"] += 1
                if len(stats["examples"]) < 5: stats["examples"].append(rel)
                entries.append(entry)
                if "Resurfaced by VaultWalker" not in text:
                    note = "> Resurfaced forgotten idea (" + datetime.now().strftime("%Y-%m-%d") + ") per post guidance. Link to MOCs for easy access.
"
                    if not args.dry_run:
                        try: open(p, "w", encoding="utf-8").write(text + note)
                        except: pass
                    stats["resurfaced_ideas"] += 1
        except: continue
    if entries:
        resurf_log.parent.mkdir(parents=True, exist_ok=True)
        with open(resurf_log, "a", encoding="utf-8") as f:
            f.write(f"
## {datetime.now().isoformat()} — {len(entries)} ideas resurfaced
" + "
".join(entries[:8]))
    return stats


def index_silo(name: str, root: Path, state: Dict) -> Dict:
    stats = {"files": 0, "dups": 0, "stale": 0, "stale_examples": []}
    if not root.exists():
        return stats
    files = [f for f in root.rglob("*") if f.is_file()]
    stats["files"] = len(files)
    seen = {}
    now = datetime.now()
    for f in files:
        h = file_hash(f)
        if h in seen:
            stats["dups"] += 1
        else:
            seen[h] = str(f)
        if (now - datetime.fromtimestamp(f.stat().st_mtime)).days > STALE_DAYS:
            stats["stale"] += 1
            if len(stats["stale_examples"]) < 3:
                stats["stale_examples"].append(str(f.relative_to(root)))
    return stats

def housekeeping_silo(name: str, root: Path) -> Dict:
    stats = {}
    silo_cfg = CFG.get("silos", {}).get(name, {})
    vision = load_vision_ref(silo_cfg.get("vision_ref", ""))
    state = load_persistent_state(name)
    is_light = is_light_cycle()
    print(f"[VAULTWALKER] {name} — {'LIGHT' if is_light else 'DEEP'} cycle (staggered)")

    idx_stats = index_silo(name, root, state)
    pf = update_per_folder_indexes(root, name, state, is_light) if silo_cfg.get("update_per_folder_indexes") else 0
    cc = clean_code_non_ascii(root) if silo_cfg.get("non_ascii_code_clean") and not is_light else 0
    mr = review_and_modify_markdowns(root, vision, name, state, is_light) if silo_cfg.get("md_review") else {}
    evo = self_evolve_extract_skills(root, name, state, is_light)
    res = resurface_forgotten_ideas(root, name, state) if not is_light else {} if not is_light else {}

    stats.update(idx_stats)
    stats["per_folder_indexes"] = pf
    stats["code_cleaned"] = cc
    stats.update({f"md_{k}": v for k, v in mr.items()})
    stats.update({f"evo_{k}": v for k, v in evo.items()})
    if "res" in locals(): stats.update({f"res_{k}": v for k, v in res.items()})
    stats["cycle_type"] = "light" if is_light else "deep"

    save_persistent_state(name, state)
    return stats

def update_manifest(name: str, stats: Dict) -> None:
    MANIFEST_DIR.mkdir(parents=True, exist_ok=True)
    ts = datetime.now().isoformat()
    manifest = {
        "silo": name,
        "timestamp": ts,
        "version": "0.5",
        "cycle": stats.get("cycle_type"),
        "stats": stats,
        "post_principles_applied": list(POST_PRINCIPLES.keys())
    }
    (MANIFEST_DIR / f"{name.lower()}-{ts[:10]}.json").write_text(json.dumps(manifest, indent=2), encoding="utf-8")

def update_trends(summary: Dict) -> None:
    if not GLOBAL_POLICIES.get("trend_tracking", True):
        return
    trends = {}
    if TRENDS_FILE.exists():
        try:
            trends = json.load(open(TRENDS_FILE))
        except:
            trends = {}
    trends.setdefault("runs", []).append({
        "ts": datetime.now().isoformat(),
        "total_files": sum(s.get("files", 0) for s in summary.values()),
        "avg_alignment": sum(s.get("md_alignment_score", 0) for s in summary.values()) / max(1, len(summary)),
        "resurfaced": sum(s.get("md_resurfaced", 0) for s in summary.values()),
        "proposals": sum(s.get("evo_proposals_generated", 0) for s in summary.values()),
        "stale_found": sum(s.get("stale", 0) for s in summary.values())
    })
    trends["total_runs"] = len(trends["runs"])
    TRENDS_FILE.write_text(json.dumps(trends, indent=2), encoding="utf-8")

def generate_report(summary: Dict, ts: str, is_light: bool) -> None:
    report_dir = Path(r"D:\PhronesisVault\Operations")
    report_dir.mkdir(parents=True, exist_ok=True)
    rpath = report_dir / f"VaultWalker-Report-{ts[:10]}.md"
    content = f"# VaultWalker v0.5 Report {ts} ({'LIGHT' if is_light else 'DEEP'})\n\n"
    content += "**Post principles fully encapsulated** (see docstring).\n**Grand Vision**: T0/T2/Wisdom Keeper.\n\n"
    for silo, s in summary.items():
        content += f"### {silo}\n- Files: {s.get('files',0)} Dups: {s.get('dups',0)} Stale: {s.get('stale',0)}\n"
        content += f"- Indexes updated: {s.get('per_folder_indexes',0)}\n- PKG entities/relations: {s.get('md_pkg_entities',0)}/{s.get('md_pkg_relations',0)}\n"
        content += f"- Resurfaced: {s.get('md_resurfaced',0)} Alignment: {s.get('md_alignment_score',0):.2f}\n"
        content += f"- Self-evo proposals: {s.get('evo_proposals_generated',0)}\n- Cycle: {s.get('cycle_type')}\n\n"
    if GLOBAL_POLICIES.get("agent_diagnostics", True):
        content += "## Simulated Agent Diagnostics (post 2073071937979347129)\n"
        content += "- Scaffolding + INDEX maps reduce wandering.\n- Estimated impact: faster navigation, fewer wrong files opened vs flat structure.\n- Recommendation: time 3 common tasks pre/post.\n\n"
    content += "## Resurfaced Forgotten Ideas & Streamlined Markdowns (max post conformity)
- Active resurfacing of 60d+ forgotten ideas into accessible lists + backlinks.
- Aggressive distill/streamline for high-signal, intuitive navigation.
- Indexes updated for easy location (MOCs + Where To Go).

## Human Verification Proposals\nSee proposals/ dir for structured diffs to review before any apply.\n"
    content += "\n**Autonomous 12h run complete.** Trends in trend_tracking.json.\n"
    rpath.write_text(content, encoding="utf-8")
    print(f"[REPORT] {rpath}")

def run_silo(name: str, root: Path) -> Tuple[str, Dict]:
    print(f"[VAULTWALKER] Starting {name}")
    if not root.exists():
        return name, {"error": "not mounted"}
    stats = housekeeping_silo(name, root)
    update_manifest(name, stats)
    return name, stats

def main():
    global args
    parser = argparse.ArgumentParser()
    parser.add_argument("--silos", nargs="*", default=list(SILOS.keys()))
    parser.add_argument("--dry-run", action="store_true")
    args = parser.parse_args()
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    summary = {}
    is_light = is_light_cycle()
    with concurrent.futures.ThreadPoolExecutor(max_workers=4) as ex:
        futures = {ex.submit(run_silo, n, SILOS[n]): n for n in args.silos if n in SILOS}
        for fut in concurrent.futures.as_completed(futures):
            name, stats = fut.result()
            summary[name] = stats
            print(f"[VAULTWALKER] {name} done: { {k:v for k,v in stats.items() if not isinstance(v, (list,dict)) or len(str(v))<100 } }")
    update_trends(summary)
    ts = datetime.now().isoformat()
    generate_report(summary, ts, is_light)
    active = f"VaultWalker v0.5 active {ts} ({'LIGHT' if is_light else 'DEEP'})"
    with open(LOG_DIR / "vaultwalker.log", "a", encoding="utf-8") as f:
        f.write(active + "\n")
    print(json.dumps({"status": "complete", "active": active, "summary": summary}, indent=2))



def evaluate_and_relocate_misplaced(root: Path, silo_name: str, dry_run: bool = False) -> Dict:
    """Enhanced data evaluation and relocation per VaultWalker thread discussion.
    Recognizes unique data signatures per silo.
    Moves misplaced content (e.g. explicit RP material) to correct vault (RoleplaySandbox).
    Evaluates during review and logs all moves for audit.
    Supports GitHub repo content hygiene as well.
    """
    moved = 0
    evaluated = 0
    log = []
    for p in root.rglob("*"):
        if not p.is_file():
            continue
        try:
            preview = p.read_text(encoding="utf-8", errors="ignore")[:500] if p.suffix in [".md", ".txt", ".py"] else ""
            target_silo = get_silo_for_content(p, preview)
            if target_silo and target_silo != silo_name:
                # Misplaced - relocate if explicit or clear mismatch
                if is_explicit_rp_content(p, preview) or "explicit" in str(p).lower():
                    if silo_name != "RoleplaySandbox":
                        relocate_to_sandbox(p, dry_run)
                        moved += 1
                        log.append(f"Moved explicit {p} to RoleplaySandbox")
                else:
                    # General misplaced data evaluation
                    log.append(f"Evaluated misplaced: {p} -> suggested {target_silo}")
                    evaluated += 1
        except:
            continue
    return {"moved": moved, "evaluated": evaluated, "log": log[:10]}

if __name__ == "__main__":
    main()