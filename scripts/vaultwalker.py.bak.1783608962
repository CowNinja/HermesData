}

def is_explicit_rp_content(path: Path, preview: str = "") -> bool:
    """Recognize explicit/roleplay material per RoleplaySandbox walled-garden rules."""
    full = str(path).lower() + " " + preview.lower()
    return any(kw in full for kw in EXPLICIT_RP_KEYWORDS)

def get_silo_for_content(path: Path, preview: str = "") -> str:
    """Recognize which silo-unique process this data belongs to (data silos processes)."""
    full = str(path).lower() + " " + preview.lower()
    best = None
    best_score = 0
    for silo, sig in SILO_SIGNATURES.items():
        score = sum(1 for kw in sig["keywords"] if kw in full)
        if score > best_score:
            best_score = score
            best = silo
    return best or "PhronesisVault"

def relocate_to_sandbox(src: Path, dry_run: bool = False) -> str:
    """Immediately move explicit material to RoleplaySandbox (walled garden isolation)."""
    target_dir = Path(r"D:\PhronesisVault\Roleplay-Sandbox\data\misplaced_from_vaultwalker")
    target_dir.mkdir(parents=True, exist_ok=True)
    dest = target_dir / src.name
    if dest.exists():
        ts = datetime.now().strftime("%Y%m%d-%H%M%S")
        dest = target_dir / f"{src.stem}_{ts}{src.suffix}"
    log_msg = f"RELOCATE: {src} -> {dest}"
    if not dry_run:
        try:
            # Simple move (shutil preferred but keep stdlib light)
            import shutil
            shutil.move(str(src), str(dest))
            log_msg += " [MOVED]"
        except Exception as e:
            log_msg += f" [ERROR: {e}]"
    else:
        log_msg += " [DRY-RUN]"
    # Audit in RoleplaySandbox
    audit = target_dir / "relocation_audit.md"
    with open(audit, "a", encoding="utf-8") as f:
            f.write("## " + datetime.now().isoformat() + " — " + str(len(entries)) + " ideas resurfaced
" + "
".join(entries[:8]))
    print(f"[VAULTWALKER-RELOCATE] {log_msg}")
    return log_msg

def cross_silo_relocation_pass(dry_run: bool = False) -> Dict:
    """Scan non-Roleplay silos for misplaced data per silo signatures. Immediate move for explicit."""
    stats = {"scanned": 0, "explicit_moved": 0, "other_misplaced": 0, "moves": []}
    for name, root in SILOS.items():
        if name == "RoleplaySandbox" or not root.exists():
            continue
        for p in root.rglob("*"):
            if not p.is_file():
                continue
            stats["scanned"] += 1
            try:
                preview = p.read_text(encoding="utf-8", errors="ignore")[:512] if p.suffix.lower() in (".md", ".txt", ".py", ".yaml") else ""
            except:
                preview = ""
            if is_explicit_rp_content(p, preview):
                # Explicit material outside sandbox -> immediately move (per user directive)
                msg = relocate_to_sandbox(p, dry_run)
                stats["explicit_moved"] += 1
                stats["moves"].append(msg)
            else:
                assigned = get_silo_for_content(p, preview)
                if assigned != name:
                    # Future: relocate other mismatches; for now flag
                    stats["other_misplaced"] += 1
    return stats

