#!/usr/bin/env python3
"""
Three-Bucket C: Drive Cleaner (Session 14+)
Autonomous, algorithmic classification for safe space management.

Buckets:
1. PROTECTED_SYSTEM   - Never touch (OS, drivers, critical system files)
2. SAFE_TO_SCRUB      - Junk / orphans that can be safely deleted
3. USEFUL_FOR_SILO    - Personal data, documents, code, Hermes artifacts, Obsidian, etc.
                        These get flagged for classification + tagging instead of deletion.

Always starts in dry-run mode. Produces a report + optional manifest.
"""

import os
import json
from pathlib import Path
from datetime import datetime, timedelta
from typing import Dict, List, Tuple

# ====================== CONFIG ======================
C_ROOT = Path("C:/")
USER_ROOT = Path.home()  # C:\Users\CowNi

PROTECTED_DIRS = [
    "Windows",
    "Program Files",
    "Program Files (x86)",
    "ProgramData",
    "$Recycle.Bin",
    "System Volume Information",
]

PROTECTED_EXTS = {".sys", ".dll", ".exe", ".drv", ".inf", ".cat", ".mui"}

SAFE_SCRUB_PATTERNS = [
    "temp", "tmp", "cache", "log", "logs",
    "download", "downloads", ".crdownload",
    "old", "bak", "backup", "autosave",
    "~$", ".tmp", ".log", ".dmp", ".etl"
]

USEFUL_PATTERNS = [
    ".pdf", ".doc", ".docx", ".txt", ".md", ".xlsx", ".csv",
    "navy", "va", "medical", "dd2807", "shpe", "service",
    "hermes", "obsidian", "phronesis", "silo", "twin", "digital",
    "personal", "finance", "family", "photo", ".jpg", ".png"
]

# Garden wall: never promote RP/explicit sandbox content to K: silo
EXCLUDED_FROM_SILO = [
    "roleplay-sandbox",
    "discord/rpg",
    "comfyui/output",
    "gallery/series",
    "visual-tags.yaml",
]

# Minimum age (days) for considering something "old orphan" in scrub zones
MIN_AGE_DAYS_FOR_SCRUB = 30

# Directories where we are more aggressive about scrubbing
AGGRESSIVE_SCRUB_DIRS = [
    USER_ROOT / "AppData/Local/Temp",
    USER_ROOT / "AppData/Roaming/Temp",
    Path("C:/Windows/Temp"),
    USER_ROOT / "Downloads",
]

OUTPUT_DIR = Path("D:/HermesData/data/c_cleanup")
OUTPUT_DIR.mkdir(parents=True, exist_ok=True)


def is_protected(path: Path) -> bool:
    """Bucket 1: Protected System"""
    try:
        parts = [p.lower() for p in path.parts]
        for prot in PROTECTED_DIRS:
            if any(prot.lower() in part for part in parts):
                return True
        if path.suffix.lower() in PROTECTED_EXTS:
            return True
        if path.name.lower() in {"pagefile.sys", "hiberfil.sys", "swapfile.sys"}:
            return True
        # System/hidden attributes on Windows (best effort)
        if os.name == 'nt':
            import ctypes
            attrs = ctypes.windll.kernel32.GetFileAttributesW(str(path))
            if attrs != -1 and (attrs & 0x04):  # SYSTEM attribute
                return True
    except Exception:
        pass
    return False


def is_excluded_from_silo(path: Path) -> bool:
    full_str = str(path).lower().replace("/", "\\")
    for frag in EXCLUDED_FROM_SILO:
        if frag in full_str:
            return True
    return False


def is_useful_for_silo(path: Path) -> bool:
    """Bucket 3: Useful data for silo / twins — conservative, high-signal only"""
    if is_excluded_from_silo(path):
        return False
    name_lower = path.name.lower()
    suffix = path.suffix.lower()
    full_str = str(path).lower()

    # Strong signals only: documents, personal keywords, project files
    strong_useful_exts = {".pdf", ".docx", ".doc", ".txt", ".md", ".xlsx", ".csv", ".py"}
    if suffix in strong_useful_exts:
        return True
    for keyword in USEFUL_PATTERNS:
        if keyword in name_lower or keyword in full_str:
            return True

    # Personal/project locations (case-insensitive)
    personal_markers = ["documents", "desktop", "hermesdata", "phronesis", "obsidian", "vault", "medical", "navy"]
    if any(x in full_str for x in personal_markers):
        return True

    # Reject common cache/junk locations even with .json etc.
    junk_locations = ["locallow", "local\\temp", "appdata\\local\\", "cache", "temporary"]
    if any(j in full_str for j in junk_locations):
        return False

    return False


def is_safe_to_scrub(path: Path) -> bool:
    """Bucket 2: Safe to delete"""
    name_lower = path.name.lower()
    full_str = str(path).lower()

    for pat in SAFE_SCRUB_PATTERNS:
        if pat in name_lower:
            return True

    # In aggressive scrub locations
    for scrub_dir in AGGRESSIVE_SCRUB_DIRS:
        try:
            if scrub_dir in path.parents or str(scrub_dir).lower() in full_str:
                return True
        except:
            pass

    # Old files in temp-like areas
    try:
        if path.is_file():
            age = datetime.now() - datetime.fromtimestamp(path.stat().st_mtime)
            if age > timedelta(days=MIN_AGE_DAYS_FOR_SCRUB) and any(d in full_str for d in ["temp", "cache", "log"]):
                return True
    except:
        pass

    return False


def classify_file(path: Path) -> str:
    if is_protected(path):
        return "PROTECTED_SYSTEM"
    if is_useful_for_silo(path):
        return "USEFUL_FOR_SILO"
    if is_safe_to_scrub(path):
        return "SAFE_TO_SCRUB"
    # Default: treat as potentially useful (conservative)
    return "USEFUL_FOR_SILO"


def analyze_c_drive(dry_run=True, max_files=5000) -> Dict:
    report = {
        "timestamp": datetime.now().isoformat(),
        "buckets": {
            "PROTECTED_SYSTEM": [],
            "SAFE_TO_SCRUB": [],
            "USEFUL_FOR_SILO": []
        },
        "summary": {},
        "total_scanned": 0,
        "total_size_by_bucket": {}
    }

    candidates = []
    scanned = 0

    # Focus on user area + common heavy spots first (safe & fast)
    search_roots = [
        USER_ROOT / "AppData",
        USER_ROOT / "Downloads",
        USER_ROOT / "Documents",
        Path("C:/Windows/Temp"),
        USER_ROOT / "Desktop",
    ]

    for root in search_roots:
        if not root.exists():
            continue
        for p in root.rglob("*"):
            if scanned >= max_files:
                break
            if p.is_file():
                try:
                    size = p.stat().st_size
                    bucket = classify_file(p)
                    report["buckets"][bucket].append({
                        "path": str(p),
                        "size_bytes": size,
                        "age_days": (datetime.now() - datetime.fromtimestamp(p.stat().st_mtime)).days
                    })
                    scanned += 1
                except Exception:
                    pass

    report["total_scanned"] = scanned

    for bucket, items in report["buckets"].items():
        total_size = sum(i["size_bytes"] for i in items)
        report["total_size_by_bucket"][bucket] = total_size
        report["summary"][bucket] = {
            "count": len(items),
            "size_mb": round(total_size / (1024*1024), 1)
        }

    # Write report
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    report_file = OUTPUT_DIR / f"c_three_bucket_dryrun_{ts}.json"
    with open(report_file, "w", encoding="utf-8") as f:
        json.dump(report, f, indent=2)

    print(f"\n=== THREE-BUCKET C: ANALYSIS (Dry Run) ===")
    print(f"Scanned: {scanned} files")
    for bucket, stats in report["summary"].items():
        print(f"  {bucket}: {stats['count']} files, {stats['size_mb']} MB")
    print(f"\nFull report saved to: {report_file}")

    return report


if __name__ == "__main__":
    print("Three-Bucket C: Cleaner — Starting dry-run analysis...")
    print("This will NOT delete anything.")
    analyze_c_drive(dry_run=True, max_files=3000)
    print("\nReview the JSON report. To execute scrub actions later, we will add a --execute flag.")
